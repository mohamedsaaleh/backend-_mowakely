# Server Configuration
NODE_ENV=development
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/legal_marketplace
MONGO_USER=admin
MONGO_PASSWORD=admin123
MONGO_DB=legal_marketplace

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@legalservices.com

# Frontend URL
FRONTEND_URL=https://mowakly-eg.vercel.app
ADMIN_URL=https://dashboard-mowakly.vercel.app
# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Platform Fee Percentage
PLATFORM_FEE_PERCENTAGE=10

# Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

BASE_URL=https://chic-encouragement-production-0618.up.railway.app/