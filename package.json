{
  "name": "legal-services-marketplace",
  "version": "1.0.0",
  "description": "Legal Services Marketplace Backend API - Production Ready",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/app.js",
    "worker": "node src/workers/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "seed": "node scripts/seed.js",
    "test": "jest --coverage --passWithNoTests --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit --coverage",
    "test:integration": "jest tests/integration --coverage",
    "test:api": "jest tests/api --coverage",
    "test:e2e": "jest tests/e2e --coverage",
    "test:sockets": "jest tests/sockets --coverage",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit --forceExit",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand --no-cache",
    "test:docker": "docker-compose -f docker-compose.test.yml up --build --abort-on-container-exit"
  },
  "keywords": [
    "legal",
    "marketplace",
    "lawyers",
    "clients",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "sharp": "^0.33.2",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "mongodb-memory-server": "^9.1.0",
    "ioredis-mock": "^8.9.0",
    "sinon": "^17.0.0",
    "nock": "^13.5.0",
    "faker": "^6.6.6",
    "jest-extended": "^4.0.0",
    "jest-junit": "^16.0.0",
    "supertest-graphql": "^1.1.0"
  }
}
